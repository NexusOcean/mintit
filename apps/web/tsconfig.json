{
  "extends": "@mintit/tsconfig/base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "incremental": false,
    "paths": {
      "@/*": ["./*"],
      "@mintit/types": ["../../packages/types/index.ts"]
    }
  },
  "include": ["src", "lib", "components", "app", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
