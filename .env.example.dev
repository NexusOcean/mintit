# =============================================================================
# Development Environment (example)
# Copy to .env.local at repo root. Loaded by `pnpm dev`.
# =============================================================================

NODE_ENV=development
ENABLED_CHAINS=xmr,firo

# --- Web ---
API_URL=http://localhost:3000/v1

# --- Shared auth ---
JWT_SECRET=jwt_secret
API_KEY=api_key
ADMIN_API_KEY=admin_key
# Optional: set a fixed code for demo-only admin login/TOTP bypass
DEMO_ADMIN_TOTP=123456
WEBHOOK_SIGNING_SECRET=webhook_secret

# --- Mongo (API connection) ---
MONGO_URI=mongodb://admin:password@localhost:27017/?authSource=admin
MONGO_DB_NAME=mint_dev

# --- Mongo (compose-only: container init — unused in pnpm dev) ---
MONGO_USERNAME=
MONGO_PASSWORD=

# --- Monero ---
MONERO_NETWORK=mainnet
MONERO_DAEMON_URI=http://localhost:18081
MONERO_DAEMON_USER=
MONERO_DAEMON_PASSWORD=
MONERO_RPC_LOGIN=
MONERO_WALLET_PATH=./data/wallet/merchant
MONERO_VIEW_KEY=
MONERO_PRIMARY_ADDRESS=
MONERO_RESTORE_HEIGHT=2142513
MONERO_PREWARM_SYNC=false

# --- Firo ---
FIRO_RPC_HOST=localhost
FIRO_RPC_PORT=8888
FIRO_RPC_USER=
FIRO_RPC_PASS=
FIRO_RPC_PROTOCOL=http

# --- Pricing ---
CMC_API_KEY=

# --- Tunable defaults ---
CONFIRMATION_DEPTH=1
INVOICE_DEFAULT_EXPIRY_SEC=3600
INVOICE_MAX_EXPIRY_SEC=7200
SCANNER_INTERVAL_MS=10000
SCANNER_LOCK_TTL_MS=30000
MONERO_SYNCED_THRESHOLD_BLOCKS=2
RATE_CACHE_TTL_MS=45000
WEBHOOK_MAX_ATTEMPTS=8
WEBHOOK_DISPATCH_INTERVAL_MS=5000
WEBHOOK_TIMEOUT_MS=10000