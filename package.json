{
  "name": "mintit",
  "private": true,
  "scripts": {
    "dev": "dotenvx run --env-file=.env.local -- turbo run dev",
    "build": "dotenvx run --env-file=.env.local -- turbo run build",
    "start": "dotenvx run --env-file=.env.local -- turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "turbo": "latest"
  },
  "packageManager": "pnpm@11.9.0",
  "devDependencies": {
    "prettier": "^3.9.4"
  }
}
